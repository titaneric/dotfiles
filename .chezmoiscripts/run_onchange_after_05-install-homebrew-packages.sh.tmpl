{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

echo "Install Homebrew packages"

find_brew() {
  if command -v brew >/dev/null 2>&1; then
    command -v brew
    return 0
  fi

  for brew_bin in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [ -x "$brew_bin" ]; then
      printf '%s\n' "$brew_bin"
      return 0
    fi
  done

  return 1
}

if ! brew_bin="$(find_brew)"; then
  echo "Homebrew is required before installing Brewfile packages" >&2
  exit 1
fi
eval "$("$brew_bin" shellenv)"

# Brewfile template hash: {{ include "Brewfile.tmpl" | sha256sum }}
# Homebrew category data hash: {{ toJson (dig "homebrew" "categories" dict .) | sha256sum }}
# Company Brewfile data hash: {{ toJson (dig "homebrew" "company" dict .) | sha256sum }}
base_brewfile="$HOME/Brewfile"
company_brewfile="$HOME/Brewfile-company"
bundle_brewfile="$base_brewfile"
tmpdir=""

cleanup() {
  if [ -n "$tmpdir" ]; then
    rm -rf "$tmpdir"
  fi
}
trap cleanup EXIT

if [ -s "$company_brewfile" ]; then
  tmpdir="$(mktemp -d)"
  bundle_brewfile="$tmpdir/Brewfile"
  cat "$base_brewfile" "$company_brewfile" > "$bundle_brewfile"
  echo "Use merged Homebrew bundle with company packages"
fi

if [ "${CHEZMOI_SKIP_BREW_UPDATE:-0}" = "1" ]; then
  echo "Skip Homebrew update"
else
  brew update
fi

brew bundle install --file="$bundle_brewfile"

echo "Homebrew packages installed"

echo "Remove Homebrew packages"

if [ "${CHEZMOI_BREW_BUNDLE_CLEANUP:-1}" = "1" ]; then
  brew bundle cleanup --force --file="$bundle_brewfile"
else
  echo "Skip Homebrew package cleanup"
fi

echo "Homebrew packages removed"

{{- end }}
