{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/usr/bin/env bash
set -euo pipefail

if command -v but >/dev/null 2>&1; then
  echo "GitButler CLI is already installed at $(command -v but)"
  but --version
  exit 0
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "curl is required to install GitButler CLI" >&2
  exit 1
fi

echo "Installing GitButler CLI"
curl -fsSL https://gitbutler.com/install.sh | sh

if ! command -v but >/dev/null 2>&1; then
  echo "GitButler CLI installation completed, but but was not found on PATH" >&2
  exit 1
fi

echo "GitButler CLI installed at $(command -v but)"
but --version
{{- end }}
