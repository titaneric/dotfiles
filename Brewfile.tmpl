{{- $common := dig "homebrew" "categories" "common" true . -}}
{{- $dev := dig "homebrew" "categories" "dev" true . -}}
{{- $devops := dig "homebrew" "categories" "devops" true . -}}
{{- $ai := dig "homebrew" "categories" "ai" true . -}}
{{- $personal := dig "homebrew" "categories" "personal" true . -}}
{{ if $devops -}}
# category: devops
tap "grafana/grafana"
tap "vectordotdev/brew"
tap "hashicorp/tap"
brew "argocd"
brew "kustomize"
brew "logcli"
brew "openstackclient"
brew "opentofu"
brew "pinact"
brew "podman"
brew "podman-compose"
brew "s3cmd"
brew "hashicorp/tap/terraform"
{{ end -}}
{{ if $common }}
# category: common
brew "atuin"
brew "bat"
brew "difftastic"
brew "direnv"
brew "dust"
brew "eza"
brew "fd"
brew "fish"
brew "fzf"
brew "gh"
brew "htop"
brew "jq"
brew "pinentry-mac"
brew "ripgrep"
brew "starship"
brew "uutils-coreutils"
brew "watch"
brew "yq"
brew "zellij"
brew "zoxide"
brew "kubectl"
# may need to execute `sudo chown -R <user> ~/Library/Application Support/Microsoft Edge` after installing `microsoft-edge` to grant the necessary permissions for Edge to access the user data directory
cask "microsoft-edge"
cask "gpg-suite"
# need to manually remove `flameshot` from Mac's System Settings / Privacy & Security / Screen and System Audio Recording by clicking the `-` button
# re-add it after installing `flameshot` to grant the necessary permissions for screen recording
cask "flameshot"
cask "visual-studio-code@insiders"
cask "spotify"
cask "alacritty"
cask "warp"
cask "zed"
{{ end -}}
{{ if $dev }}
# category: dev
brew "openssl@3"
brew "cryptography"
brew "git-absorb"
brew "git-crypt"
brew "git-filter-repo"
brew "libgpg-error"
brew "go"
brew "golangci-lint"
brew "goreleaser"
brew "gpgme"
brew "hurl"
brew "just"
brew "pkgconf"
brew "pre-commit"
brew "sccache"
brew "uv"
brew "node"
{{ end -}}
{{ if $ai }}
# category: ai
brew "anomalyco/tap/opencode"
cask "gitbutler"
brew "rtk"
brew "worktrunk"
{{ end -}}
{{ if $personal }}
# category: personal
brew "typst"
brew "zola"
{{ end -}}
