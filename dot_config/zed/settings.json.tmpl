{{- $apiURL := dig "zed" "languageModels" "openaiCompatible" "genaiGateway" "apiURL" "" . -}}
// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "language_models": {
    "openai_compatible": {
      "GenAI Gateway": {
        "api_url": {{ $apiURL | quote }},
        "available_models": [
          {
            "name": "gpt-5.5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
              "interleaved_reasoning": false,
            },
          },
        ],
      },
    },
    "opencode": {
      "show_free_models": false,
      "show_go_models": false,
      "show_zen_models": false,
    },
  },
  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "model": "openai/gpt-5.5",
      },
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "minimap": {
    "show": "auto",
  },
  "base_keymap": "VSCode",
  "icon_theme": "Material Icon Theme",
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "One Dark",
  },
  "terminal": {
    "shell": {
      "program": "fish",
    },
  },
}
