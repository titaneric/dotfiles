{{- $isCompanyComputer := dig "opencode" "isCompanyComputer" false . -}}
{{- $model := dig "opencode" "model" "" . -}}
{{- $enabledProviders := list -}}
{{- $providers := list -}}
{{- $providerMap := dict -}}
{{- if $isCompanyComputer -}}
{{- $enabledProviders = dig "opencode" "enabledProviders" list . -}}
{{- $providers = dig "opencode" "providers" list . -}}
{{- range $provider := $providers -}}
{{- if $provider.id -}}
{{- $providerConfig := omit $provider "id" "models" -}}
{{- $models := get $provider "models" -}}
{{- if $models -}}
{{- $modelMap := dict -}}
{{- range $providerModel := $models -}}
{{- if $providerModel.id -}}
{{- $_ := set $modelMap $providerModel.id (omit $providerModel "id") -}}
{{- end -}}
{{- end -}}
{{- $_ := set $providerConfig "models" $modelMap -}}
{{- end -}}
{{- $_ := set $providerMap $provider.id $providerConfig -}}
{{- end -}}
{{- end -}}
{{- end -}}
{{- $mcpServers := list -}}
{{- if and $isCompanyComputer (dig "opencode" "mcp" "enabled" true .) -}}
{{- $mcpServers = dig "opencode" "mcp" "servers" list . -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 0
  },
  "permission": {
    "external_directory": {
      "~/*": "allow",
    }
  },
{{- if $model }}
  "model": "{{ $model }}",
{{- end }}
{{- if and $isCompanyComputer $enabledProviders }}
  "enabled_providers": {{ $enabledProviders | toPrettyJson | trimSuffix "\n" | replace "\n" "\n  " }},
{{- end }}
  "plugin": [
    "@devtheops/opencode-plugin-otel",
    "./plugins/agentmemory-capture.ts",
    "superpowers@git+https://github.com/obra/superpowers.git",
  ],
{{- if and $isCompanyComputer $providerMap }}
  "provider": {{ $providerMap | toPrettyJson | trimSuffix "\n" | replace "\n" "\n  " }},
{{- end }}
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "environment": {},
      "enabled": true
    }{{- range $server := $mcpServers }},
    "{{ $server.name }}": {{ omit $server "name" | toPrettyJson | trimSuffix "\n" | replace "\n" "\n    " }}{{- end }}
  }
}
