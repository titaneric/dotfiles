  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "environment": {},
      "enabled": true
    },
    "confluence": {
      "type": "local",
      "environment": {
        "BUN_CONFIG_REGISTRY": "https://npm.linecorp.com"
      },
      "command": [
        "npx",
        "@linecorp/flava-mcp-connector@latest",
        "https://confluence-noahs.kks.mcp.prd.flava.workers-infra.com/mcp"
      ],
      "enabled": false
    },
    "slack": {
      "type": "local",
      "environment": {
        "BUN_CONFIG_REGISTRY": "https://npm.linecorp.com"
      },
      "command": [
        "npx",
        "@linecorp/flava-mcp-connector@latest",
        "https://slack-noahs.kks.mcp.prd.flava.workers-infra.com/mcp"
      ],
      "enabled": false
    },
    "grafana": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-grafana"
      ],
      "environment": {
        "GRAFANA_URL": "https://observe.line.dev",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_TOKEN}"
      },
      "enabled": false
    },
    "terraform": {
      "type": "local",
      "command": [
        "podman",
        "run",
        "-i",
        "-e",
        "LOG_DEBUG",
        "-e",
        "TFE_TOKEN",
        "--rm",
        "hashicorp/terraform-mcp-server"
      ],
      "environment": {
        "TFE_TOKEN": "${env:TF_APP_TOKEN}",
        "LOG_LEVEL": "debug",
      },
      "enabled": false
    },
    "k8s": {
      "type": "local",
      "command": [
        "kubectl-ai",
        "--mcp-server",
      ],
      "enabled": false
    },
  }
